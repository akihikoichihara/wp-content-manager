# WordPress Authentication
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_application_password

# For multi-site setups, add per-site credentials:
# WP_EXAMPLE_COM_USERNAME=your_wp_username
# WP_EXAMPLE_COM_APP_PASSWORD=your_application_password

# X.com (Twitter) API - optional, for x-daily-post.js
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret
X_SITE_ID=example.com
X_SITE_NAME=My Site Name
X_HASHTAGS=#YourHashtag1 #YourHashtag2

# Google Gemini API - required for x-daily-post.js post text generation
GOOGLE_API_KEY=your_google_api_key
